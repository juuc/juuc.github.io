---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

const KO_SITE_TITLE = `블로그 · ${SITE_TITLE}`;
const KO_SITE_DESCRIPTION = '주우철의 React Native 및 React 프론트엔드 개발 블로그.';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'ko')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={KO_SITE_TITLE} description={KO_SITE_DESCRIPTION} lang="ko" />
		<style>
			.page-header {
				margin-bottom: 2em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.page-header h1 {
				margin: 0;
			}
			.page-header .lang-link {
				font-size: 0.9em;
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.page-header .lang-link:hover {
				color: var(--accent);
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				padding: 1.5em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.post-list h2 {
				font-size: 1.35em;
				margin: 0 0 0.35em 0;
				color: rgb(var(--black));
				transition: color 0.2s ease;
			}
			.post-list a:hover h2 {
				color: var(--accent);
			}
			.post-list .description {
				margin: 0 0 0.5em 0;
				color: rgb(var(--gray-dark));
				font-size: 0.95em;
			}
			.post-list .meta {
				margin: 0;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.empty {
				color: rgb(var(--gray));
				text-align: center;
				padding: 3em 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>블로그</h1>
				<a class="lang-link" href="/blog/">🇺🇸 English →</a>
			</div>
			{
				posts.length === 0 ? (
					<p class="empty">아직 한국어 글이 없어요.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h2>{post.data.title}</h2>
									<p class="description">{post.data.description}</p>
									<p class="meta">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>
