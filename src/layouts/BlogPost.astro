---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, lang, translation } = Astro.props;
const htmlLang = lang ?? 'en';
const switcherLabel = htmlLang === 'en' ? '🇰🇷 한국어로 보기' : '🇺🇸 Read in English';

// Build hreflang map from the frontmatter `translation` field.
// On an English post: translation points at 'ko/[slug]'.
// On a Korean post: translation points at '[slug]' (relative to /blog/).
const currentPath = Astro.url.pathname;
const translations = translation
	? htmlLang === 'en'
		? { en: currentPath, ko: `/blog/${translation}/` }
		: { en: `/blog/${translation}/`, ko: currentPath }
	: undefined;
---

<html lang={htmlLang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			lang={htmlLang}
			translations={translations}
		/>
		<style>
			main {
				padding-top: 1.5em;
			}
			article {
				max-width: var(--content-width);
				margin: 0 auto;
			}
			.hero-image {
				margin-bottom: 1.5em;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.lang-switcher {
				margin-bottom: 1.5em;
				font-size: 0.9em;
			}
			.lang-switcher a {
				display: inline-block;
				text-decoration: none;
				color: rgb(var(--gray));
				border: 1px solid rgb(var(--gray-light));
				padding: 0.3em 0.9em;
				border-radius: 999px;
				transition: 0.2s ease;
			}
			.lang-switcher a:hover {
				color: var(--accent);
				border-color: var(--accent);
				background: rgba(var(--gray-light), 0.4);
			}
			.post-header {
				margin-bottom: 2em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-header h1 {
				margin: 0 0 0.5em 0;
				line-height: 1.2;
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin: 0;
			}
			.last-updated-on {
				font-style: italic;
				margin-left: 0.5em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					translation && (
						<div class="lang-switcher">
							<a
								href={`/blog/${translation}/`}
								lang={htmlLang === 'en' ? 'ko' : 'en'}
							>
								{switcherLabel}
							</a>
						</div>
					)
				}
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}
				<header class="post-header">
					<h1>{title}</h1>
					<p class="post-meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									· Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
