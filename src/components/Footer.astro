---
const today = new Date();
---

<footer>
	<p class="copyright">&copy; {today.getFullYear()} Ju Woocheol</p>
	<p class="links">
		<a href="https://github.com/juuc" target="_blank" rel="noopener noreferrer">GitHub</a>
		<span aria-hidden="true">·</span>
		<a href="https://juuc.github.io/portfolio/" target="_blank" rel="noopener noreferrer">Portfolio</a>
		<span aria-hidden="true">·</span>
		<a href="/rss.xml">RSS</a>
	</p>
</footer>
<style>
	footer {
		padding: 3em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.9em;
	}
	.copyright {
		margin: 0 0 0.25em 0;
	}
	.links {
		margin: 0;
	}
	.links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.links a:hover {
		color: var(--accent);
	}
	.links span {
		margin: 0 0.5em;
	}
</style>
