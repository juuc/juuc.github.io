---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { GA4_ID, SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	/**
	 * Language of the current page. Used to render hreflang alternates.
	 * Omit on pages that are not part of the bilingual system (home, about).
	 */
	lang?: 'en' | 'ko';
	/**
	 * Absolute paths for the same page in each language.
	 * Example on an English post with a Korean translation:
	 *   { en: '/blog/my-post/', ko: '/blog/ko/my-post/' }
	 * When provided, hreflang alternates are emitted. x-default points to English.
	 */
	translations?: { en?: string; ko?: string };
	/** Set to true on blog post pages to emit og:type="article" instead of "website". */
	isArticle?: boolean;
	/** ISO date string for article:published_time OG tag. */
	pubDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, lang, translations, isArticle, pubDate } = Astro.props;

function absoluteUrl(path: string) {
	return new URL(path, Astro.site).toString();
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

{/* Korean font (Pretendard) — served from a CDN so global.css fallback works even for first paint */}
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
<link
	rel="stylesheet"
	href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
/>

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

{/* hreflang alternates for bilingual pages */}
{
	translations && translations.en && (
		<link rel="alternate" hreflang="en" href={absoluteUrl(translations.en)} />
	)
}
{
	translations && translations.ko && (
		<link rel="alternate" hreflang="ko" href={absoluteUrl(translations.ko)} />
	)
}
{
	translations && translations.en && (
		<link rel="alternate" hreflang="x-default" href={absoluteUrl(translations.en)} />
	)
}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{lang && <meta http-equiv="content-language" content={lang} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={isArticle ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />
{lang && <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />}
{isArticle && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{isArticle && <meta property="article:author" content="https://juuc.github.io" />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

{/* GA4 — only loads when GA4_ID is set in consts.ts */}
{GA4_ID && (
	<Fragment set:html={`
		<script async src="https://www.googletagmanager.com/gtag/js?id=${GA4_ID}"></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', '${GA4_ID}', {
				page_path: '${Astro.url.pathname}',
				content_group: '${lang ?? "en"}',
				send_page_view: true
			});
		</script>
	`} />
)}
